# ── Django ─────────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-this-with-a-real-secret-key-in-production
DEBUG=True

# ── Redis (required for real-time WebSocket support) ──────────────────────────
# Install: brew install redis  OR  sudo apt install redis-server
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── Stripe (optional – enables Pro subscription payments) ─────────────────────
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Get from: https://dashboard.stripe.com/webhooks (after registering webhook)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Create a recurring price at: https://dashboard.stripe.com/products
# e.g. ₹299/month recurring price
STRIPE_PRICE_ID=price_your_monthly_price_id_here

# ── Google Gemini (AI assistant in chat) ───────────────────────────────────────
# API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyCbIXbAVkY0sS9mRMiua9YAoBfPU2MUZAc
# Optional: gemini-2.5-flash (default), gemini-2.5-flash-lite, gemini-1.5-flash, etc.
# Note: gemini-2.0-flash is deprecated and often returns 404 — prefer 2.5 or 1.5.
GEMINI_MODEL=gemini-2.5-flash

# ── GIF picker in chat (Giphy is used first; Tenor is optional fallback) ──────
# Primary: https://developers.giphy.com/docs/api/
GIPHY_API_KEY=lrr3FLwM8Ac4ZFrUTrjMivnbooo0muns
# Optional Tenor fallback (new API keys are often unavailable)
# TENOR_CLIENT_KEY is a short label for your app (not secret).
TENOR_API_KEY=
TENOR_CLIENT_KEY=spark_chat
