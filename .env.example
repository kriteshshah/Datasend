# ── Django ─────────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-this-with-a-real-secret-key-in-production
DEBUG=True

# ── Redis (required for real-time WebSocket support) ──────────────────────────
# Install: brew install redis  OR  sudo apt install redis-server
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── Stripe (optional – enables Pro subscription payments) ─────────────────────
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Get from: https://dashboard.stripe.com/webhooks (after registering webhook)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Create a recurring price at: https://dashboard.stripe.com/products
# e.g. ₹299/month recurring price
STRIPE_PRICE_ID=price_your_monthly_price_id_here
